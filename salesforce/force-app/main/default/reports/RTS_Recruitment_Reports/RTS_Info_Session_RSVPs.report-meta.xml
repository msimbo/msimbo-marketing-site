<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Info-session RSVPs grouped by session datetime. Shows attendance rate and how many session leads went on to apply (RecordType flipped to RTS_Applicant). Includes both current Info Session Leads and promoted Applicants who retain Info_Session_Date.</description>
    <columns>
        <field>EMAIL</field>
    </columns>
    <columns>
        <field>Lead.RTS_Info_Session_Source__c</field>
    </columns>
    <columns>
        <field>Lead.RTS_Info_Session_Attended__c</field>
    </columns>
    <columns>
        <field>RECORDTYPE</field>
    </columns>
    <columns>
        <field>STATUS</field>
    </columns>
    <columns>
        <field>CREATED_DATE</field>
    </columns>
    <filter>
        <criteriaItems>
            <column>Lead.RTS_Info_Session_Date__c</column>
            <operator>notEqual</operator>
            <value></value>
        </criteriaItems>
    </filter>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>Lead.RTS_Info_Session_Date__c</field>
        <sortOrder>Desc</sortOrder>
    </groupingsDown>
    <name>RTS Info Session RSVPs</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
    <reportType>LeadList</reportType>
    <scope>allusers</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <timeFrameFilter>
        <dateColumn>CREATED_DATE</dateColumn>
        <endDate>2030-12-31</endDate>
        <interval>INTERVAL_CUSTOM</interval>
        <startDate>2020-01-01</startDate>
    </timeFrameFilter>
</Report>
