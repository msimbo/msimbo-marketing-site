<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>RTS_Send_Application_Received</fullName>
        <description>Sends RTS Application Received email (includes Criteria Core assessment link) when a new RTS Website Lead is created. Invoked by Flow 1.</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderAddress>programs@ulem.org</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>RTS_Email_Templates/RTS_Application_Received</template>
    </alerts>
    <alerts>
        <fullName>RTS_Send_Instructor_Interview_Invitation</fullName>
        <description>Sends RTS Instructor Interview Invitation email with Lunacal booking link when Coordinator moves Lead to Interview 1 Requested. Invoked by Flow 2.</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderAddress>programs@ulem.org</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>RTS_Email_Templates/RTS_Instructor_Interview_Invitation</template>
    </alerts>
    <alerts>
        <fullName>RTS_Send_Case_Manager_Interview_Invitation</fullName>
        <description>Sends RTS Case Manager Interview Invitation email with Lunacal booking link when Coordinator advances Lead to Interview 2 Requested. Invoked by Flow 3.</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderAddress>programs@ulem.org</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>RTS_Email_Templates/RTS_Case_Manager_Interview_Invitation</template>
    </alerts>
    <alerts>
        <fullName>RTS_Send_Offer_of_Admission</fullName>
        <description>Sends RTS Offer of Admission email when Coordinator moves Lead to Accepted - Offer Sent. Invoked by Flow 4.</description>
        <protected>false</protected>
        <recipients>
            <type>creator</type>
        </recipients>
        <senderAddress>programs@ulem.org</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>RTS_Email_Templates/RTS_Offer_of_Admission</template>
    </alerts>
    <alerts>
